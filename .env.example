# 이 파일을 .env로 복사한 후 실제 값을 채워넣으세요.
# cp .env.example .env
# .env 파일은 절대 git에 커밋하지 마세요 (.gitignore로 이미 제외됨).

# 한국투자증권 KIS OpenAPI
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
# paper = 모의투자, real = 실전투자
KIS_ENV=paper

# 데이터베이스 (Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stockdb

# 이 파일을 .env로 복사한 후 실제 값을 채워넣으세요.
# cp .env.example .env
# .env 파일은 절대 git에 커밋하지 마세요 (.gitignore로 이미 제외됨).

# 한국투자증권 KIS OpenAPI
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
# paper = 모의투자, real = 실전투자 (앱키는 환경별 별도 발급 — docs/architecture.md ADR-1)
KIS_ENV=real

# 데이터베이스 (Supabase Postgres)
# transaction-mode pooler(6543) URL. 예:
# postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=
# session-mode pooler(5432) — 마이그레이션용 (선택)
DIRECT_URL=

# 네이버 검색 API (뉴스 수집용) — https://developers.naver.com
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
